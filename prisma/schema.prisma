generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model User {
  id               String          @id @default(uuid()) @db.Uuid
  email            String          @unique @db.VarChar(320)
  passwordHash     String          @map("password_hash") @db.VarChar(255)
  passwordAuthEnabled Boolean      @default(true) @map("password_auth_enabled")
  nickname         String          @db.VarChar(50)
  profileImageUrl  String?         @map("profile_image_url") @db.Text
  status           UserStatus      @default(ACTIVE)
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  blockedByUsers   UserBlock[]     @relation("BlockedUser")
  blockingUsers    UserBlock[]     @relation("BlockingUser")
  favoriteGames    FavoriteGame[]
  passwordResetTokens PasswordResetToken[]
  refreshTokens    RefreshToken[]
  reportsSubmitted Report[]        @relation("UserReports")
  reviews          Review[]
  socialAccounts   SocialAccount[]

  @@map("users")
}

model RefreshToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash") @db.Char(64)
  deviceName String?   @map("device_name") @db.VarChar(100)
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.Char(64)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
  @@index([usedAt])
  @@map("password_reset_tokens")
}

model Review {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  gameId    String   @map("game_id") @db.VarChar(100)
  rating    Decimal  @db.Decimal(2, 1)
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@index([gameId, createdAt])
  @@index([userId, createdAt])
  @@map("reviews")
}

model FavoriteGame {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  gameId    String   @map("game_id") @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
  @@index([userId])
  @@index([gameId])
  @@map("favorite_games")
}

model SocialAccount {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  provider        String   @db.VarChar(30)
  providerSubject String   @map("provider_subject") @db.VarChar(255)
  createdAt       DateTime @default(now()) @map("created_at")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubject])
  @@unique([userId, provider])
  @@index([userId])
  @@map("social_accounts")
}

model Report {
  id             String   @id @default(uuid()) @db.Uuid
  reporterUserId String   @map("reporter_user_id") @db.Uuid
  targetType     String   @map("target_type") @db.VarChar(20)
  targetId       String   @map("target_id") @db.VarChar(100)
  reason         String   @db.VarChar(50)
  detail         String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at")
  reporterUser   User     @relation("UserReports", fields: [reporterUserId], references: [id], onDelete: Cascade)

  @@index([reporterUserId, createdAt])
  @@index([targetType, targetId, createdAt])
  @@map("reports")
}

model UserBlock {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  blockedUserId String   @map("blocked_user_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")
  blockedUser   User     @relation("BlockedUser", fields: [blockedUserId], references: [id], onDelete: Cascade)
  user          User     @relation("BlockingUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, blockedUserId])
  @@index([userId, createdAt])
  @@index([blockedUserId, createdAt])
  @@map("user_blocks")
}

model SearchQuery {
  id              String   @id @default(uuid()) @db.Uuid
  query           String   @db.VarChar(100)
  normalizedQuery String   @map("normalized_query") @db.VarChar(100)
  resultCount     Int      @map("result_count")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([normalizedQuery, createdAt])
  @@index([createdAt])
  @@map("search_queries")
}
